# Sao chép file này thành .env.local rồi điền giá trị thật của bạn.
# KHÔNG commit file .env.local (đã có trong .gitignore) — chỉ file .env.example
# (toàn placeholder, không có secret thật) mới được đưa lên Git.

GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Mật khẩu đăng nhập trang /admin — ĐỔI mật khẩu này trước khi deploy thật
ADMIN_PASSWORD=change_this_password

# Cloudinary — dùng để upload ảnh/video sản phẩm trực tiếp từ trang Admin
# Lấy tại: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SEO — domain thật khi deploy (dùng cho canonical URL, sitemap.xml, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Tag Manager — MỌI tracking (GA4 + Meta Pixel) đi qua GTM, để trống
# thì site vẫn chạy bình thường, chỉ là không có tracking.
# Lấy tại: https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=

# GA4 Measurement ID — KHÔNG nhúng trực tiếp vào site, chỉ dùng để tạo GA4
# Configuration Tag bên trong GTM (đọc biến này qua Data Layer Variable).
# Lấy tại: https://analytics.google.com (Admin → Data Streams)
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID — KHÔNG nhúng trực tiếp, chỉ dùng để tạo Meta Pixel
# Tag bên trong GTM (đọc qua Data Layer Variable "fb_pixel_id").
# Lấy tại: https://business.facebook.com/events_manager
NEXT_PUBLIC_FB_PIXEL_ID=
